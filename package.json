{
  "name": "openclaw-memory-system",
  "version": "1.0.0",
  "description": "OpenClaw 记忆系统：Obsidian vault 自动同步、Qdrant 向量检索、零 LLM 成本压缩会话观察、自愈健康监控。Multi-layer memory for OpenClaw agents.",
  "author": "OpenClaw Community",
  "license": "MIT",
  "keywords": ["openclaw", "memory", "记忆", "vault", "qdrant", "obsidian", "vector-search", "向量检索", "agent-memory", "知识库", "knowledge-management", "llm", "embedding"],
  "openclaw": {
    "skill": true,
    "minVersion": "2026.5.0",
    "requires": {
      "python": ">=3.10",
      "services": ["qdrant"],
      "optional_services": ["lmstudio"],
      "pip": ["requests", "numpy"],
      "optional_pip": ["mem0ai"]
    },
    "hooks": {
      "recommended": ["session-memory", "memory-compact", "memory-extract"]
    },
    "cron": {
      "recommended": [
        {
          "name": "heartbeat",
          "schedule": "every 45m",
          "command": "python scripts/maintenance_orchestrator.py --cycle light --parallel"
        },
        {
          "name": "heartbeat-heavy",
          "schedule": "every 6h",
          "command": "python scripts/maintenance_orchestrator.py --cycle heavy --parallel"
        }
      ]
    }
  },
  "files": [
    "SKILL.md",
    "README.md",
    "package.json",
    "requirements.txt",
    "docker-compose.yml",
    "scripts/*.py",
    "templates/*",
    "docs/*"
  ]
}
